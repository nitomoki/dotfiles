{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "id=\"${TMUX_PANE:-$(jq -r .session_id)}\"; echo idle > \"/tmp/claude-status-${id}\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "id=\"${TMUX_PANE:-$(jq -r .session_id)}\"; echo running > \"/tmp/claude-status-${id}\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "id=\"${TMUX_PANE:-$(jq -r .session_id)}\"; echo idle > \"/tmp/claude-status-${id}\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/push-notify.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "id=\"${TMUX_PANE:-$(jq -r .session_id)}\"; f=\"/tmp/claude-status-${id}\"; [ \"$(cat \"$f\" 2>/dev/null)\" = running ] && echo waiting > \"$f\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/push-notify.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "id=\"${TMUX_PANE:-$(jq -r .session_id)}\"; rm -f \"/tmp/claude-status-${id}\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-code-setup@claude-plugins-official": true,
    "claude-obsidian@claude-obsidian-marketplace": false
  },
  "extraKnownMarketplaces": {
    "claude-obsidian-marketplace": {
      "source": {
        "source": "github",
        "repo": "AgriciDaniel/claude-obsidian"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
